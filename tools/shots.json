    { "name": "modern-antietam-hero", "gfx": "modern", "battle": "antietam", "side": "US", "settle": 1500, "tier": "high",
      "postEval": "(function(){try{var c=__M3D.camera,t=__M3D.controls.target;var dx=c.position.x-t.x,dz=c.position.z-t.z;var k=0.42;c.position.set(t.x+dx*k, c.position.y*0.5+6, t.z+dz*k);__M3D.controls.update();return 'dollied in';}catch(e){return 'ERR '+e.message;}})()" },
    { "name": "modern-antietam-fx", "gfx": "modern", "battle": "antietam", "side": "US", "settle": 320, "tier": "high",
      "postEval": "(function(){try{G.settings.reduceMotion=false;var c=__M3D.camera,t=__M3D.controls.target;var dx=c.position.x-t.x,dz=c.position.z-t.z;var k=0.46;c.position.set(t.x+dx*k, c.position.y*0.55+7, t.z+dz*k);__M3D.controls.update();var B=G.battle,n=0;for(var i=0;i<B.units.length&&n<7;i++){var u=B.units[i];if(!u.alive)continue;if(u.side===B.enemySide&&!u.spotted)continue;if(typeof emitFX==='function'){emitFX('fire',u.c,u.r);emitFX('smoke',u.c,u.r);emitFX('num',u.c,u.r,{n:18+n*9});}n++;}return 'fx on '+n+' units; fxlen='+(G.fx?G.fx.length:0);}catch(e){return 'ERR '+e.message;}})()" },
    { "name": "modern-probe-badge", "gfx": "modern", "battle": "antietam", "side": "US", "settle": 280, "tier": "high",
      "postEval": "(function(){try{G.settings.reduceMotion=false;var B=G.battle,M=B.M;var u=null;for(var i=0;i<B.units.length;i++){var x=B.units[i];if(x.alive&&x.side===B.playerSide&&x.type!=='hq'){u=x;break;}}if(!u){for(var j=0;j<B.units.length;j++){if(B.units[j].alive&&B.units[j].side===B.playerSide){u=B.units[j];break;}}}if(!u)return 'no friendly';var tile=M.map[M.key(u.c,u.r)],elev=tile?(tile.elev||0):0;var w=_m3dWorld(u.c,u.r,0),topY=_m3dTileH(elev);var tx=w.x,ty=topY+3,tz=w.z;__M3D.controls.target.set(tx,ty,tz);__M3D.camera.position.set(tx+6,ty+7,tz+11);__M3D.controls.update();if(typeof emitFX==='function'){emitFX('fire',u.c,u.r);emitFX('smoke',u.c,u.r);emitFX('num',u.c,u.r,{n:42});}return 'probe '+(u.vetName||u.type)+' str='+u.strength+'/'+u.maxStr+' fxlen='+(G.fx?G.fx.length:0);}catch(e){return 'ERR '+e.message;}})()" },
    { "name": "modern-weather-fog", "gfx": "modern", "battle": "antietam", "side": "US", "settle": 1100, "tier": "high",
      "postEval": "(function(){try{G.battle.wx='fog';if(typeof _m3dApplyAtmosphere==='function')_m3dApplyAtmosphere();if(typeof draw==='function')draw();return 'wx=fog';}catch(e){return 'ERR '+e.message;}})()" },
    { "name": "modern-weather-rain", "gfx": "modern", "battle": "gettysburg", "side": "US", "settle": 1100, "tier": "high",
      "postEval": "(function(){try{G.battle.wx='rain';if(typeof _m3dApplyAtmosphere==='function')_m3dApplyAtmosphere();if(typeof draw==='function')draw();return 'wx=rain';}catch(e){return 'ERR '+e.message;}})()" },
    { "name": "modern-probe-fx", "gfx": "modern", "battle": "antietam", "side": "US", "settle": 170, "tier": "high",
      "postEval": "(function(){try{G.settings.reduceMotion=false;var B=G.battle,M=B.M;var u=null;for(var i=0;i<B.units.length;i++){var x=B.units[i];if(x.alive&&x.side===B.playerSide&&x.type!=='hq'){u=x;break;}}if(!u)return 'no friendly';var tile=M.map[M.key(u.c,u.r)],elev=tile?(tile.elev||0):0;var w=_m3dWorld(u.c,u.r,0),topY=_m3dTileH(elev);var tx=w.x,tz=w.z;__M3D.controls.target.set(tx,topY+4,tz);__M3D.camera.position.set(tx+3,topY+2.2,tz+9);__M3D.controls.update();if(typeof emitFX==='function'){emitFX('num',u.c,u.r,{n:73});emitFX('fire',u.c,u.r);for(var q=0;q<3;q++)emitFX('smoke',u.c,u.r);}return 'fx '+(u.vetName||u.type)+' fxlen='+(G.fx?G.fx.length:0);}catch(e){return 'ERR '+e.message;}})()" }
