  "purpose": "Optional local Tripo/GLB tactical unit model slots. The game never calls Tripo at runtime; it only consumes vetted local GLB/GLTF files when they exist.",
  "policy": {
    "runtimeMode": "local-files-only",
    "freePlanCaveat": "Use Tripo Ultra Mesh / detailed geometry when the current Tripo UI makes it available on the free plan. Verify the UI before spending credits and never bypass a paywall.",
    "ultraQualityRequired": "Canonical Tripo source slots must declare geometryQuality=detailed, textureQuality=detailed, pbr=true, smartLowPoly=true, and an ultraSourcePath. Runtime assets remain optimized GLB/GLTF files.",
    "sourceMeshUse": "Detailed/Ultra source meshes are source art only. Runtime assets must be optimized low-poly GLB/GLTF files.",
    "maxRuntimeBytes": 1500000,
    "maxRuntimeVertices": 20000,
    "maxRuntimeTriangles": 12000,
    "defaultRuntimeEnabled": false
  },
