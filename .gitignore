# deps / tooling
node_modules/
package-lock.json
# OS + scratch
.DS_Store
*.log
.scratch/
.ccout*
# local-only Claude settings (the all-Bash allowlist shouldn't ship)
.claude/settings.local.json
# local-only API keys for the asset pipeline — NEVER commit
secrets.local.json
*.local.json
.secrets/
# visual-regression + probe output — regenerable; kept out of source control so the
# pending-changes view stays quiet (keep only the milestone before/after record)
tools/shots/*.png
tools/shots/*.jpg
tools/shots/*.json
tools/shots/*.log
tools/shots/*.webm
tools/shots/session-video/
!tools/shots/milestone-*.png
!tools/shots/baseline-*.png
!tools/shots/after-*.png
# autonomous-run scratch (probe TMPDIR + build/commit temp files)
.tmp/
# backups (incl. timestamped snapshots)
*.bak
*.bak-*

# editor
.vscode/
# codex local tooling config (environment-specific MCP registration — not project work)
.codex/
# local-only settings/doc snapshots (contain user-level ~/.claude files — never ship)
backups/
*.code-workspace
